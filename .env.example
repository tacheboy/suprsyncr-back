# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=suprsyncr_db
DB_USERNAME=postgres
DB_PASSWORD=postgres

# JWT
JWT_SECRET=change-this-to-a-secure-256-bit-secret-in-production

# Encryption (must be exactly 32 bytes)
# ENCRYPTION_KEY=12345678901234567890123456789012

# OpenAI — get your key at https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# AWS S3 (leave test/test for LocalStack)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
S3_BUCKET_NAME=suprsyncr-product-images
S3_ENDPOINT=http://localhost:4566

# Shopify OAuth (optional)
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
SHOPIFY_REDIRECT_URI=http://localhost:8080/shopify/callback
# Public HTTPS API base URL (ngrok/cloudflared locally) used for Shopify webhook delivery.
SHOPIFY_WEBHOOK_BASE_URL=https://api.example.com

# Autopilot agent microservice
AGENT_SERVICE_URL=http://localhost:8081

# Server
SERVER_PORT=8080

INTERNAL_SERVICE_TOKEN=service-token
BACKEND_BASE_URL=http://localhost:8080
